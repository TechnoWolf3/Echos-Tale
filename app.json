{
  "expo": {
    "name": "Echo’s Tale",
    "slug": "echos-tale",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "echostale",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.technowolf3.echostale",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.technowolf3.echostale"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/icon.png",
      "name": "Echo’s Tale",
      "shortName": "Echo’s Tale",
      "themeColor": "#060712",
      "backgroundColor": "#060712"
    },
    "plugins": [
  "expo-router",
  [
    "expo-splash-screen",
    {
      "image": "./assets/images/echo-logo-feathered.png",
      "imageWidth": 240,
      "resizeMode": "contain",
      "backgroundColor": "#060712",
      "dark": {
        "backgroundColor": "#060712"
      }
    }
  ],
  "expo-secure-store"
],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "83f7fa21-2fb6-4c8c-8a07-c909912286b3"
      }
    },
    "owner": "technowolf3"
  }
}
