{
  "buildCommand": "npm run vercel-build",
  "cleanUrls": true,
  "devCommand": "npm run web",
  "framework": null,
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/echo-api/:path*",
      "destination": "https://echo-of-elsewhere-production.up.railway.app/:path*"
    },
    {
      "source": "/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/_expo/:path*",
      "destination": "/_expo/:path*"
    },
    {
      "source": "/favicon.ico",
      "destination": "/favicon.ico"
    },
    {
      "source": "/:path*",
      "destination": "/"
    }
  ]
}
