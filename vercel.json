{
  "buildCommand": "npm run vercel-build",
  "cleanUrls": true,
  "devCommand": "npm run web",
  "framework": null,
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/echo-api/:path*",
      "destination": "https://echo-of-elsewhere-production.up.railway.app/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/"
    }
  ]
}
